#!/usr/bin/env bash
# Block pushes that introduce BSH-internal markers to this OSS repo.
# Pre-push is the right place for this gate: pre-commit already catches
# most cases locally, and CI scanning only catches leaks AFTER they hit
# GitHub. This hook scans the diff between the local commits and what
# the remote already has.
set -euo pipefail

PATTERN='bshg\.com|boschdevcloud|github-bshg|eforms-online|s\.a\.x\.|MasterLayout|rb-proxy|\.bosch\.com|Bosch Siemens|MUM3RE|YeHVV89kL7aKBQbZWT9k93hLA7kfdfg2uRNrYfd22Y|eyJpZGVudGlmaWVyIjo'

zero='0000000000000000000000000000000000000000'
fail=0

# Each line of stdin is: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue   # branch deletion, nothing to scan

  if [ "$remote_sha" = "$zero" ]; then
    # New branch on remote — diff against the merge-base with origin/main as the baseline.
    git fetch origin main --quiet 2>/dev/null || true
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null || git rev-list --max-parents=0 "$local_sha" | tail -1)
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Exclude the scanner files from their own pattern-matching.
  HITS=$(git diff "$range" -U0 \
      -- ':!*.svg' ':!*.jpg' ':!*.pptx' \
         ':!.githooks/*' ':!.github/workflows/leak-scan.yml' \
      | grep -E "^\+" | grep -E "$PATTERN" || true)
  BIN_HITS=$(git diff --name-only "$range" --diff-filter=A | grep -E '\.(svg|jpg|pptx)$' | grep -E 'eyJpZGVudGlmaWVyIjo' || true)

  if [[ -n "$HITS" || -n "$BIN_HITS" ]]; then
    echo "ERROR: pre-push leak scan found BSH markers in $local_ref ($range):" >&2
    [[ -n "$HITS" ]] && echo "$HITS" >&2
    [[ -n "$BIN_HITS" ]] && echo "BSH asset-id binaries: $BIN_HITS" >&2
    fail=1
  fi
done

if [ $fail -eq 1 ]; then
  echo >&2
  echo "If this is a false positive, use 'git push --no-verify' AFTER manual review." >&2
  exit 1
fi
