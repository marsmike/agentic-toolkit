{
  "$schema": "https://schemas.designtokens.org/draft-2/format.json",
  "$description": "Feinschliff — eponymous default brand pack. Indigo palette + Noto Sans. MIT.",
  "color": {
    "$type": "color",
    "accent":       { "$value": "#2C5FE8", "$description": "Indigo — primary brand accent" },
    "accent-hover": { "$value": "#1E47B8", "$description": "Deeper indigo for hover/emphasis" },
    "highlight":    { "$value": "#6B8AEC", "$description": "Soft indigo tint" },
    "black":        { "$value": "#0A0E1A", "$description": "Near-black with a cool cast" },
    "ink":          { "$value": "#1A1F2E", "$description": "Body ink" },
    "graphite":     { "$value": "#5C6470", "$description": "Secondary text" },
    "steel":        { "$value": "#8A92A0", "$description": "Muted labels" },
    "silver":       { "$value": "#B8BEC8", "$description": "Disabled / hairlines on dark" },
    "fog":          { "$value": "#DDE1E8", "$description": "Hairlines, dividers" },
    "paper":        { "$value": "#F2F4F8", "$description": "Cool off-white surface" },
    "white":        { "$value": "#FFFFFF" }
  },
  "font-family": {
    "$type": "fontFamily",
    "display": { "$value": ["Noto Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "body":    { "$value": ["Noto Sans", "Helvetica Neue", "Arial", "sans-serif"] },
    "mono":    { "$value": ["Noto Sans Mono", "ui-monospace", "Menlo", "monospace"] }
  },
  "font-weight": {
    "$type": "fontWeight",
    "light":   { "$value": 300 },
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 },
    "bold":    { "$value": 700 }
  },
  "font-size": {
    "$type": "dimension",
    "$description": "Sizes match the shared 1920x1080 baseline.",
    "display":     { "$value": "160px" },
    "huge":        { "$value": "120px" },
    "slide-title": { "$value": "37px" },
    "sub":         { "$value": "44px" },
    "body":        { "$value": "26px" },
    "eyebrow":     { "$value": "18px" },
    "footer":      { "$value": "16px" },
    "pgmeta":      { "$value": "18px" },
    "kpi-value":   { "$value": "120px" },
    "kpi-unit":    { "$value": "40px" },
    "kpi-key":     { "$value": "16px" },
    "kpi-delta":   { "$value": "18px" },
    "col-num":     { "$value": "14px" },
    "col-title":   { "$value": "36px" },
    "col-body":    { "$value": "22px" },
    "btn":         { "$value": "22px" },
    "chip":        { "$value": "16px" },
    "bar-label":   { "$value": "28px" },
    "bar-num":     { "$value": "22px" },
    "quote":       { "$value": "84px" },
    "quote-attr":  { "$value": "20px" },
    "bignum":      { "$value": "320px" },
    "agenda-num":  { "$value": "18px" },
    "agenda-t":    { "$value": "28px" },
    "agenda-d":    { "$value": "20px" }
  },
  "slide": {
    "$type": "dimension",
    "width":  { "$value": "1920px" },
    "height": { "$value": "1080px" },
    "padding-x": { "$value": "100px" },
    "padding-y-top":    { "$value": "100px" },
    "padding-y-bottom": { "$value": "80px" }
  }
}
